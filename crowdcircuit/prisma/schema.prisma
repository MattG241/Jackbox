generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rating {
  FAMILY
  STANDARD
}

enum RoomStatus {
  LOBBY
  IN_MATCH
  ENDED
}

enum MatchStatus {
  PENDING
  RUNNING
  FINISHED
}

enum RoundPhase {
  IDLE
  SUBMIT
  REVEAL
  VOTE
  SCORE
  DONE
}

enum FlagReason {
  PROFANITY
  HARASSMENT
  OFFTOPIC
  OTHER
}

enum SubmissionKind {
  TEXT
  DRAWING
  QUIZ
  TAP
  PERCENT
  TRACE
  COLOR
  HOLD
}

model Room {
  id              String     @id @default(cuid())
  code            String     @unique
  status          RoomStatus @default(LOBBY)
  hostPlayerId    String?    @unique
  // Shared secret encoded in the TV's "Remote" QR. Any phone that presents
  // this token gets host-level command authority for the room.
  // Nullable so `prisma db push` can add the column to existing rows — old
  // rooms surface the "Remote unavailable" fallback until recreated.
  remoteToken     String?    @default(cuid())
  familyMode      Boolean    @default(false)
  streamerMode    Boolean    @default(false)
  selectedGameId  String     @default("guesspionage")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  players Player[]
  matches Match[]
  flags   ModerationFlag[]

  @@index([status])
}

model Player {
  id            String   @id @default(cuid())
  roomId        String
  displayName   String
  sessionToken  String   @unique
  isAudience    Boolean  @default(false)
  // True for phone-as-remote controllers. Remote players are non-playing
  // (also isAudience = true) but are authorized to issue host commands.
  isRemote      Boolean  @default(false)
  connected     Boolean  @default(true)
  avatarColor   String   @default("#ff4f7b")
  avatarEmoji   String   @default("🎲")
  // Discriminator for which avatar to render. EMOJI uses avatarEmoji +
  // avatarColor. DRAWING + PHOTO use avatarImage (a JSON drawing blob or
  // a compressed data: URL respectively).
  avatarKind    String   @default("EMOJI")
  avatarImage   String?
  joinedAt      DateTime @default(now())
  lastSeenAt    DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  submissions Submission[]
  votes       Vote[]
  scoreEvents ScoreEvent[]

  @@index([roomId])
  @@unique([roomId, displayName])
}

model Match {
  id            String      @id @default(cuid())
  roomId        String
  gameId        String      @default("hot-take-hustle")
  status        MatchStatus @default(PENDING)
  totalRounds   Int         @default(5)
  currentRound  Int         @default(0)
  startedAt     DateTime?
  endedAt       DateTime?

  room   Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  rounds Round[]

  @@index([roomId])
  @@index([gameId])
}

model Round {
  id           String     @id @default(cuid())
  matchId      String
  roundNumber  Int
  phase        RoundPhase @default(IDLE)
  promptId     String
  criterionId  String
  phaseEndsAt  DateTime?
  createdAt    DateTime   @default(now())
  // For multi-stage games (e.g. Stroke of Genius, Mash-Up Doodle). 0 for
  // single-stage games.
  stage        Int        @default(0)
  totalStages  Int        @default(1)

  match       Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  prompt      Prompt       @relation(fields: [promptId], references: [id])
  criterion   Criterion    @relation(fields: [criterionId], references: [id])
  submissions Submission[]
  votes       Vote[]
  scoreEvents ScoreEvent[]

  @@unique([matchId, roundNumber])
}

model Prompt {
  id        String   @id @default(cuid())
  gameId    String   @default("hot-take-hustle")
  text      String
  truth     String?
  // For quiz games: JSON array of choice strings (shown alongside truth).
  choices   String?
  // Optional hint/image or setup shown with the prompt.
  detail    String?
  rating    Rating   @default(STANDARD)
  tag       String?
  createdAt DateTime @default(now())

  rounds Round[]

  @@index([gameId])
  @@index([rating])
}

model Criterion {
  id        String   @id @default(cuid())
  gameId    String   @default("hot-take-hustle")
  label     String
  rating    Rating   @default(STANDARD)
  hint      String?
  createdAt DateTime @default(now())

  rounds Round[]

  @@index([gameId])
  @@index([rating])
}

model Submission {
  id        String         @id @default(cuid())
  roundId   String
  playerId  String
  kind      SubmissionKind @default(TEXT)
  // TEXT: the raw answer. DRAWING: JSON serialized Drawing.
  // QUIZ: JSON { choiceIndex: number, wager: number }.
  // TAP: JSON { score: number, hits: number, misses: number, fastestMs: number }.
  // TRACE: JSON { score: number, accuracy: number }.
  // COLOR: JSON { r: number, g: number, b: number }.
  text      String
  // Stage within a multi-stage round (0 for single-stage games).
  stage     Int            @default(0)
  createdAt DateTime       @default(now())

  round  Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  votes  Vote[]

  @@unique([roundId, playerId, stage])
  @@index([roundId])
}

model Vote {
  id           String   @id @default(cuid())
  roundId      String
  voterId      String
  // Null for "truth" votes in fib-style games (where the voter picks the hidden
  // ground truth rather than another player's submission).
  submissionId String?
  forTruth     Boolean  @default(false)
  weight       Float    @default(1.0)
  createdAt    DateTime @default(now())

  round      Round       @relation(fields: [roundId], references: [id], onDelete: Cascade)
  voter      Player      @relation(fields: [voterId], references: [id], onDelete: Cascade)
  submission Submission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([roundId, voterId])
  @@index([submissionId])
}

model ScoreEvent {
  id        String   @id @default(cuid())
  roundId   String
  playerId  String
  points    Int
  reason    String
  createdAt DateTime @default(now())

  round  Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
}

model ModerationFlag {
  id        String     @id @default(cuid())
  roomId    String?
  content   String
  reason    FlagReason @default(OTHER)
  notes     String?
  createdAt DateTime   @default(now())

  room Room? @relation(fields: [roomId], references: [id], onDelete: SetNull)
}
